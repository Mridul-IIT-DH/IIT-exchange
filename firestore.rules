rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 1. GLOBAL IDENTITY & INTEGRITY HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    
    // Admin: Authorization for specific campus managers and developers
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '04KEOwkoiNMRjPN5fPeSXUkv3Kg2' ||
        request.auth.token.email == 'cs24mt002@iitdh.ac.in' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Student: Mandatory IITDH domain check + account verification
    // This is the core 'Enterprise' gate for campus security.
    function isIITStudent() {
      return isSignedIn() && 
             request.auth.token.email.lower().matches('.+@iitdh\\.ac\\.in$') &&
             request.auth.token.email_verified == true;
    }

    // Data Flow Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Default Deny: All paths are locked by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 2. USER PROFILE DIRECTORY (/users)
    // ---------------------------------------------------------
    match /users/{userId} {
      // Browsing users is restricted to Admins
      allow list: if isAdmin();
      
      // Individual profile cards accessible by Owner or Admin
      allow get: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      
      // Registration: Strictly bound to user's UID to prevent profile stealing
      allow create: if isIITStudent() && userId == request.auth.uid && isValidId(userId);

      // Self-Service updates: Restricted to specific fields to prevent role hijacking
      allow update: if isAdmin() || (
        isIITStudent() && 
        userId == request.auth.uid && 
        incoming().uid == userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'listingsCountToday', 'wishlist'])
      );
      
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 3. MARKETPLACE INVENTORY (/products)
    // ---------------------------------------------------------
    match /products/{productId} {
      // UNIFIED SECURITY: Only verified campus members can browse the marketplace.
      // This protects student PII from general internet scrapers and search engines.
      allow read, list: if isSignedIn();
      
      // SCHEMA ENFORCEMENT: Prevents resource exhaustion (Denial of Wallet)
      function isValidProduct(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.description is string && data.description.size() <= 5000 &&
               data.price is number && data.price >= 0 &&
               (!("productAge" in data) || (data.productAge is string && data.productAge.matches('^(Brand New \\(Unused \\/ Sealed\\)|Less than 1 month|1 to 6 months|6 to 12 months|1 to 2 years|More than 2 years)$'))) &&
               data.sellerId is string && data.sellerId.size() <= 128 &&
               data.status is string && data.status.matches('^(active|sold|expired|archived)$') &&
               (!("expiresAt" in data) || data.expiresAt is timestamp);
      }

      allow create: if isIITStudent() && 
                    isValidId(productId) &&
                    incoming().sellerId == request.auth.uid &&
                    isValidProduct(incoming()) &&
                    incoming().status == 'active';
      
      allow update: if isAdmin() || (
        isIITStudent() && 
        existing().sellerId == request.auth.uid &&
        isValidProduct(incoming()) &&
        incoming().sellerId == existing().sellerId && // IMMUTABLE: Seller can't be changed
        (
          // Action: Mark Sold
          (incoming().status == 'sold' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
          // Action: Relist (reset expiry and status)
          ((existing().status == 'archived' || existing().status == 'expired') && incoming().status == 'active' && incoming().diff(existing()).affectedKeys().hasAll(['status', 'expiresAt', 'createdAt']) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'expiresAt', 'createdAt', 'updatedAt'])) ||
          // Action: General Edit
          (incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'productAge', 'images', 'category', 'updatedAt', 'tags', 'isPriceNegotiable', 'isPriceFixed']))
        )
      ) || (
        // ATOMIC ANALYTICS: Prevents data poisoning in view counts
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'contactClicks']) &&
        (incoming().views == existing().views + 1 || incoming().views == existing().views) &&
        (incoming().contactClicks == existing().contactClicks + 1 || incoming().contactClicks == existing().contactClicks)
      );
      
      allow delete: if isAdmin() || (isIITStudent() && existing().sellerId == request.auth.uid);
    }

    // ---------------------------------------------------------
    // 4. ADMINISTRATIVE SYSTEM (/admins)
    // ---------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn(); // Verify who is an admin for local caching
      allow write: if false; // Role elevations must happen via Server/Console for 2FA security
    }
    // ---------------------------------------------------------
    // 5. SYSTEM PROBES
    // ---------------------------------------------------------
    match /_internal_/healthcheck {
      allow get: if true; // Publicly readable health check to verify backend reachability
    }
  }
}
