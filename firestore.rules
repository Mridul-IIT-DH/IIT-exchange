rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // MASTER ADMINISTRATIVE OVERRIDE
    // ---------------------------------------------------------
    match /{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == '04KEOwkoiNMRjPN5fPeSXUkv3Kg2' ||
        request.auth.token.email == 'cs24mt002@iitdh.ac.in'
      );
    }

    // Default Deny (for non-admins)
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helper
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '04KEOwkoiNMRjPN5fPeSXUkv3Kg2' ||
        request.auth.token.email == 'cs24mt002@iitdh.ac.in'
      );
    }

    function isIITStudent() {
      return isSignedIn() && 
             request.auth.token.email.lower().matches('.+@iitdh\\.ac\\.in$') &&
             request.auth.token.email_verified == true;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Support Queries
    match /queries/{queryId} {
      allow list, get: if isAdmin();
      allow create: if isIITStudent() && isValidId(queryId) &&
                   incoming().message is string && incoming().message.size() <= 2000;
      allow update, delete: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isIITStudent() && userId == request.auth.uid && isValidId(userId);
      allow update: if isAdmin() || (
        isIITStudent() && 
        userId == request.auth.uid && 
        incoming().phone is string && incoming().phone.size() <= 20
      );
      allow delete: if isAdmin();
    }

    // Marketplace Listings
    match /products/{productId} {
      allow read, list: if true;
      allow create: if isIITStudent() && isValidId(productId) &&
                   incoming().title is string && incoming().title.size() <= 100;
      allow update: if isAdmin() || (
        isIITStudent() && 
        existing().sellerId == request.auth.uid &&
        incoming().sellerId == existing().sellerId &&
        incoming().title is string && incoming().title.size() <= 100
      ) || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'contactClicks'])
      );
      allow delete: if isAdmin() || (isIITStudent() && resource.data.sellerId == request.auth.uid);
    }

    // Admin List
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
