rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 1. GLOBAL IDENTITY HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    
    // Admin: Authorization via hardcoded fallback or document lookup
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '04KEOwkoiNMRjPN5fPeSXUkv3Kg2' ||
        request.auth.token.email == 'cs24mt002@iitdh.ac.in'
      );
    }

    // Student: Mandatory IITDH domain check + verification
    function isIITStudent() {
      return isSignedIn() && 
             request.auth.token.email.lower().matches('.+@iitdh\\.ac\\.in$') &&
             request.auth.token.email_verified == true;
    }

    // Integrity: ID format enforcement
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Data Shortcuts
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---------------------------------------------------------
    // 2. USER DIRECTORY (/users)
    // ---------------------------------------------------------
    match /users/{userId} {
      // List: Admin oversight
      allow list: if isAdmin();
      
      // Get: Owner or Administrator
      allow get: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      
      // Create: Strictly bound student identity
      allow create: if isIITStudent() && userId == request.auth.uid && isValidId(userId) &&
                   incoming().phone is string && incoming().phone.size() <= 20;

      // Update: Owner (profile sync) or Admin (moderation)
      allow update: if isAdmin() || (
        isIITStudent() && 
        userId == request.auth.uid && 
        incoming().phone is string && incoming().phone.size() <= 20 &&
        incoming().uid == userId
      );
      
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 3. MARKETPLACE INVENTORY (/products)
    // ---------------------------------------------------------
    match /products/{productId} {
      // Visibility: Full public read for current campus offerings
      allow read, list: if true;
      
      // Creation: Verified student sellers only
      allow create: if isIITStudent() && isValidId(productId) &&
                   incoming().title is string && incoming().title.size() <= 100 &&
                   incoming().sellerId == request.auth.uid;
      
      // Moderation & Interaction:
      allow update: if isAdmin() || (
        // Self-service update
        isIITStudent() && 
        existing().sellerId == request.auth.uid &&
        incoming().sellerId == existing().sellerId &&
        incoming().title is string && incoming().title.size() <= 100
      ) || (
        // Public signals (Analytics)
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'contactClicks'])
      );
      
      allow delete: if isAdmin() || (
        isIITStudent() && 
        existing().sellerId == request.auth.uid
      );
    }

    // ---------------------------------------------------------
    // 4. ADMINISTRATIVE SYSTEM (/admins)
    // ---------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
