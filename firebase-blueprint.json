{
  "entities": {
    "User": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth UID" },
        "name": { "type": "string", "description": "Full student name from Google" },
        "email": { "type": "string", "description": "Primary @iitdh.ac.in email" },
        "phone": { "type": "string", "description": "WhatsApp/Contact number" },
        "createdAt": { "type": "number", "description": "Timestamp of profile creation" },
        "listingsCountToday": { "type": "number", "description": "Daily anti-spam counter" },
        "wishlist": { "type": "array", "description": "Array of saved product IDs" }
      },
      "required": ["uid", "name", "email", "phone", "createdAt", "wishlist"]
    },
    "Admin": {
      "title": "Admin Permission",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super", "moderator"] }
      }
    },
    "Product": {
      "title": "Marketplace Listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "productAge": { "type": "string", "description": "e.g. 6 Months, 2 Years" },
        "price": { "type": "number" },
        "isPriceNegotiable": { "type": "boolean" },
        "images": { "type": "array" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerEmail": { "type": "string" },
        "sellerPhone": { "type": "string" },
        "createdAt": { "type": "number" },
        "expiresAt": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "sold", "expired"] },
        "contactClicks": { "type": "number" },
        "views": { "type": "number" }
      },
      "required": ["title", "price", "sellerId", "createdAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data including wishlist"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Public marketplace items"
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Hard-coded admin permission document"
    }
  }
}
