# Environment File Pattern for Deployment (e.g. Render)
# Do NOT commit raw API keys to GitHub
# Copy the values from your AI Studio UI environment and inject them into your hosting provider dashboard

# Server & Framework Requirements
NODE_ENV=production
PORT=3000
PUBLIC_URL=
RESEND_FROM_EMAIL=

# Cloudinary Setup for Picture Storage
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Firebase Admin/App Setup (If needed externally)
# The frontend automatically picks up the firebase connection details from firebase-applet-config.json

# Resend API for Magic Links
RESEND_API_KEY=
JWT_SECRET=

# Firebase Admin (Required for Render/Cloud environments)
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content as a single line or string
FIREBASE_SERVICE_ACCOUNT_KEY=
